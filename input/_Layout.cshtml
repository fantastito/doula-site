<!DOCTYPE html>
<html lang="@(Model.ContainsKey("Language") ? Model["Language"] : "fr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(Model.ContainsKey("Title") ? Model["Title"] : "Dem A Ca")</title>
    <meta name="description" content="@(Model.ContainsKey("Description") ? Model["Description"] : "Accompagnement doula bienveillant et conscient")">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main>
        <div class="hero">
            <h1>Dem A Ca</h1>
            <p class="subtitle">Naître, ensemble</p>
            
            <div class="hero-services">
                <div class="hero-service-item">
                    <strong>Accompagnement prénatal</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Présence à l'accouchement</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Accompagnement postnatal</strong>
                </div>
            </div>

            <a href="#contact" class="cta-button">Prendre rendez-vous</a>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </main>

    @RenderSection("Scripts", required: false)
    
    @Html.Partial("_contact-section")

    <footer>
        <p>Pour la belle urgence d'un cœur de mère ❤️🥂☀️</p>
        <p>&copy; @(DateTime.Now.Year) Jeanne Ponté</p>
    </footer>

</body>
</html>
