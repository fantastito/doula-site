<!DOCTYPE html>
<html lang="@(Model.ContainsKey("Language") ? Model["Language"] : "fr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(Model.ContainsKey("Title") ? Model["Title"] : "Dem A Ca")</title>
    <meta name="description" content="@(Model.ContainsKey("Description") ? Model["Description"] : "Accompagnement doula bienveillant et conscient")">
    
    <style>
        /* CSS Variables - Brand Palette */
        :root {
            --color-earth: #C9897A;
            --color-cream: #E8D5BC;
            --color-off-white: #F5EDEO;
            --color-beige: #C4956A;
            --color-dark: #2a2420;
            --color-light: #faf8f6;
            --color-bg-alt: #ebe5e0;
        }

        /* Reset & Base */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'Georgia', 'Garamond', serif;
            line-height: 1.7;
            color: var(--color-dark);
            background-color: var(--color-off-white);
            font-size: 16px;
        }

        /* Typography */
        h1 {
            font-size: 4rem;
            font-weight: 300;
            letter-spacing: 3px;
            color: var(--color-dark);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        h2 {
            font-size: 2.2rem;
            font-weight: 400;
            color: var(--color-beige);
            margin: 0 0 2rem 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h3 {
            font-size: 1.4rem;
            font-weight: 500;
            color: var(--color-beige);
            margin: 1.5rem 0 0.75rem 0;
        }

        p {
            margin-bottom: 1.2rem;
            font-size: 1.05rem;
            line-height: 1.8;
        }

        strong {
            color: var(--color-beige);
            font-weight: 600;
        }

        em {
            font-style: italic;
            color: var(--color-earth);
        }

        /* Links */
        a {
            color: var(--color-beige);
            text-decoration: none;
            border-bottom: 1px solid var(--color-cream);
            transition: all 0.3s ease;
        }

        a:hover {
            color: var(--color-earth);
            border-bottom-color: var(--color-earth);
        }

        /* CTA Button */
        .cta-button {
            display: inline-block;
            padding: 14px 36px;
            margin: 2rem 0 0 0;
            background-color: var(--color-beige);
            color: var(--color-off-white);
            border: 2px solid var(--color-beige);
            border-radius: 0;
            font-family: 'Georgia', serif;
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            border-bottom: none;
        }

        .cta-button:hover {
            background-color: transparent;
            color: var(--color-beige);
            border-color: var(--color-beige);
        }

        /* Hero Section - Full Screen */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: linear-gradient(135deg, var(--color-off-white) 0%, var(--color-cream) 100%);
            padding: 4rem 2rem;
            animation: fadeIn 0.8s ease-out;
        }

        .hero h1 {
            margin-bottom: 0.75rem;
        }

        .hero .subtitle {
            font-size: 1.4rem;
            color: var(--color-earth);
            font-weight: 300;
            letter-spacing: 1px;
            margin-bottom: 2rem;
        }

        /* Services List in Hero */
        .hero-services {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 3rem;
            max-width: 900px;
            justify-self: center;
        }

        .hero-service-item {
            padding: 1.5rem;
            background-color: rgba(255, 255, 255, 0.6);
            border-top: 3px solid var(--color-beige);
            text-align: center;
            transition: all 0.3s ease;
        }

        .hero-service-item:hover {
            background-color: rgba(255, 255, 255, 0.9);
            border-top-color: var(--color-earth);
        }

        .hero-service-item strong {
            display: block;
            font-size: 0.95rem;
            color: var(--color-beige);
        }

        .hero-service-item span {
            display: none;
        }

        /* Full-screen Sections */
        section {
            min-height: auto;
            padding: 6rem 2rem;
            max-width: 100%;
        }

        section:nth-child(odd) {
            background-color: var(--color-off-white);
        }

        section:nth-child(even) {
            background-color: var(--color-bg-alt);
        }

        .section-content {
            max-width: 700px;
            margin: 0 auto;
        }

        section h2 {
            margin-bottom: 2rem;
        }

        hr {
            border: none;
            height: 1px;
            background-color: var(--color-cream);
            margin: 3rem 0;
        }

        /* Lists */
        ul {
            margin: 1.5rem 0 1.5rem 2rem;
        }

        li {
            margin-bottom: 1rem;
        }

        /* Service Cards */
        .services {
            display: grid;
            gap: 2.5rem;
            margin: 2rem 0;
        }

        .service {
            padding: 2rem;
            border-left: 4px solid var(--color-beige);
            background-color: rgba(201, 137, 122, 0.08);
            transition: all 0.3s ease;
        }

        .service:hover {
            border-left-color: var(--color-earth);
            background-color: rgba(201, 137, 122, 0.15);
            transform: translateY(-4px);
        }

        .service h3 {
            margin-top: 0;
            color: var(--color-beige);
            margin-bottom: 0.75rem;
        }

        .service p {
            margin-bottom: 0;
            color: var(--color-dark);
        }

        /* Testimonials */
        .testimonials {
            display: grid;
            gap: 2rem;
            margin: 2rem 0;
        }

        .testimonial {
            padding: 2rem;
            background-color: rgba(201, 137, 122, 0.05);
            border-top: 3px solid var(--color-beige);
            italic: true;
            line-height: 1.8;
        }

        .testimonial p {
            margin-bottom: 1rem;
            font-style: italic;
            color: var(--color-dark);
        }

        .testimonial strong {
            display: block;
            margin-top: 1rem;
            font-style: normal;
            color: var(--color-beige);
        }

        /* Footer Section */
        footer {
            background-color: var(--color-cream);
            padding: 4rem 2rem;
            margin-top: 0;
            text-align: center;
            min-height: auto;
        }

        footer p {
            font-style: italic;
            color: var(--color-earth);
            font-size: 1.1rem;
        }

        /* Main Content */
        main {
            min-height: auto;
        }

        .content {
            width: 100%;
            padding: 0;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            h1 {
                font-size: 2.5rem;
                letter-spacing: 1.5px;
            }

            h2 {
                font-size: 1.6rem;
            }

            .hero {
                min-height: 80vh;
                padding: 2rem 1.5rem;
            }

            .hero .subtitle {
                font-size: 1.1rem;
            }

            section {
                padding: 4rem 1.5rem;
            }

            .hero-services {
                margin-top: 2rem;
            }

            .service {
                padding: 1.5rem;
            }
        }

        /* Animations */
        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        main {
            animation: fadeIn 0.8s ease-out;
        }

        section {
            animation: fadeIn 0.6s ease-out;
        }
    </style>
</head>
<body>
    <main>
        <div class="hero">
            <h1>Dem A Ca</h1>
            <p class="subtitle">Naître, ensemble</p>
            <a href="#contact" class="cta-button">Prendre rendez-vous</a>
            
            <div class="hero-services">
                <div class="hero-service-item">
                    <strong>Accompagnement prénatal</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Présence à l'accouchement</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Accompagnement postnatal</strong>
                </div>
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </main>

    <footer>
        <p>Pour la belle urgence d'un cœur de mère ❤️🥂☀️</p>
    </footer>
</body>
</html>
