<!DOCTYPE html>
<html lang="@(Model.ContainsKey("Language") ? Model["Language"] : "fr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(Model.ContainsKey("Title") ? Model["Title"] : "Dem A Ca")</title>
    <meta name="description" content="@(Model.ContainsKey("Description") ? Model["Description"] : "Accompagnement doula bienveillant et conscient")">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main>
        <div class="hero">
            <img src="/assets/images/logo.jpeg" alt="Dem A Ca — Naître, Ensemble" class="hero-logo">
            
            <div class="hero-services">
                <div class="hero-service-item">
                    <strong>Accompagnement individuel</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Présence à la naissance</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Massage rituel</strong>
                </div>
                <div class="hero-service-item">
                    <strong>Massage bébé</strong>
                </div>
            </div>

            <a href="#contact" class="cta-button">Prendre rendez-vous</a>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </main>

    @RenderSection("Scripts", required: false)
    
    @Html.Partial("_contact-section")

    <footer>
        <p class="disclaimer">
            Les informations et l'accompagnement proposés sont de nature non médicale.
            Je ne suis pas médecin, sage-femme ni professionnelle de santé, et mon rôle
            de doula ne remplace en aucun cas un suivi médical.
        </p>
        <p class="copyright">&copy; @(DateTime.Now.Year) Jeanne Ponté</p>
    </footer>

</body>
</html>
